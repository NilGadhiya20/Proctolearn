# Server Configuration
PORT=5000
NODE_ENV=development
BACKEND_URL=http://localhost:5000

# Database Configuration
MONGODB_URI=mongodb://localhost:27017/proctolearn
MONGODB_USER=
MONGODB_PASSWORD=
MONGODB_URI_FALLBACK=mongodb://127.0.0.1:27017/proctolearn
DISABLE_DB_FALLBACK=false
MONGODB_SERVER_SELECTION_TIMEOUT_MS=8000
MONGODB_SOCKET_TIMEOUT_MS=45000

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRE=7d
REFRESH_TOKEN_SECRET=your_refresh_token_secret_here

# Email Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
EMAIL_FROM=noreply@proctolearn.com

# Frontend Configuration
FRONTEND_URL=http://localhost:3000

# Security
CORS_ORIGIN=http://localhost:3000

# Session Configuration
SESSION_SECRET=your_session_secret_here

# Redis Configuration (Optional for production)
REDIS_URI=redis://localhost:6379

# File Upload
MAX_FILE_SIZE=5242880
UPLOAD_DIR=./uploads

# Activity Monitoring
ACTIVITY_LOG_INTERVAL=5000
TAB_CHANGE_ALERT_THRESHOLD=3
